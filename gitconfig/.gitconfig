[user]
  name = Kirill Beznisko
  email = beznisko.k@proton.me
[core]
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  light = false
  side-by-side = false
  line-numbers = true
  syntax-theme = OneHalfDark

[includeIf "gitdir: ~/work_station/work"]
  path = "~/.gitconfig-work"
