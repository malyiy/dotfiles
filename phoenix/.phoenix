#!/bin/bash

eval "$(/opt/homebrew/bin/brew shellenv)"

# Error handling wrapper — captures stderr and displays in red on failure
__run() {
  local cmd_name="$1"; shift
  local _stderr _ec
  { _stderr=$("$@" 2>&1 1>&3 3>&-); } 3>&1
  _ec=$?
  if [ $_ec -ne 0 ]; then
    printf '\033[31mError with command %s: %s\033[0m\n' "$cmd_name" "${_stderr:-exit code $_ec}" >&2
    return $_ec
  fi
}

# Commands

## Movement
l()   { __run l eza -a -l -h --tree --level=1 --icons=always --no-user "$@"; }
lt()  { __run lt eza -a -l -h --tree --level=1 --icons=always --no-user --total-size "$@"; }
ll()  { __run ll eza -a -l --tree --level=2 --icons=always --no-user --no-permissions --no-filesize "$@"; }
lll() { __run lll eza -a -l --tree --level=2 --icons=always --no-user --no-permissions --no-filesize "$@"; }

..() {
  local _err
  _err=$(cd .. 2>&1)
  if [ $? -ne 0 ]; then
    printf '\033[31mError with command ..: %s\033[0m\n' "$_err" >&2
    return 1
  fi
  cd ..
}

...() {
  local _err
  _err=$(cd ../.. 2>&1)
  if [ $? -ne 0 ]; then
    printf '\033[31mError with command ...: %s\033[0m\n' "$_err" >&2
    return 1
  fi
  cd ../..
}

....() {
  local _err
  _err=$(cd ../../.. 2>&1)
  if [ $? -ne 0 ]; then
    printf '\033[31mError with command ....: %s\033[0m\n' "$_err" >&2
    return 1
  fi
  cd ../../..
}

## Programs
v()   { __run v nvim "$@"; }
lg()  { __run lg lazygit "$@"; }
cc()  { __run cc claude "$@"; }
ccd() { __run ccd claude --dangerously-skip-permissions --chrome "$@"; }
x()   { __run x hx "$@"; }
ql()  { __run ql qlmanage -p "$@"; }

## Utils
yrid()           { __run yrid ~/utils/build-react-native-for-my-iphone.sh "$@"; }
bi()             { __run bi ~/utils/bi.sh "$@"; }
bd()             { __run bd ~/utils/bd.sh "$@"; }
dotsync()        { __run dotsync ~/utils/dotsync.sh "$@"; }
checkinstalled() { __run checkinstalled ~/utils/checkinstalled.sh "$@"; }

export REACT_EDITOR=zed
